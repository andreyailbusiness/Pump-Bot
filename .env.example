APP_ENV=dev
TRADING_MODE=paper
# true = real MEXC futures orders (use only with small LIVE_MAX_NOTIONAL_USDT and real API keys).
LIVE_ENABLED=false
MEXC_API_KEY=
MEXC_API_SECRET=
# With TRADING_MODE=live + futures: pull open swap positions from MEXC (survives deploys).
MEXC_EXCHANGE_POSITION_SYNC=true

MEXC_BASE_URL=https://api.mexc.com
QUOTE_ASSET=USDT
MARKET_TYPE=futures

TOP_SYMBOLS_LIMIT=120
# Futures: filter turnover list like backtest --daily-reselect (score + quantile). Cached once per UTC day.
LIVE_DAILY_RESELECT=true
LIVE_DAILY_LOOKBACK_DAYS=14
LIVE_DAILY_SCORE_QUANTILE=0.75
# 0 = keep all symbols at/above quantile (matches --daily-top-n 0).
LIVE_DAILY_TOP_N=0
STATE_PATH=data/state.json
TOP_SYMBOLS_CACHE_PATH=data/top_symbols.json
STATE_BACKUP_ENABLED=true
STATE_BACKUP_INTERVAL_SEC=900
STATE_BACKUP_DIR=data/backups
STATE_BACKUP_KEEP=96
GITHUB_STATE_SYNC_ENABLED=false
GITHUB_STATE_REPO=
GITHUB_STATE_FILE_PATH=data/render_state.json
GITHUB_STATE_BRANCH=main
GITHUB_STATE_TOKEN=
GITHUB_STATE_TIMEOUT_SEC=15
GITHUB_STATE_SYNC_INTERVAL_SEC=300
GITHUB_STATE_COMMIT_MESSAGE=chore(state): sync bot runtime state

TIMEFRAME=15m
CANDLES_LIMIT=300
# Seconds between full bot passes (MEXC position sync, scans). 60 ≈ each minute; raise if you hit rate limits.
BOT_POLL_INTERVAL_SEC=15

RISK_PERCENT=0.01
RISK_PERCENT_STRONG=0.015
RISK_PERCENT_NEUTRAL=0.015
RISK_PERCENT_WEAK=0.015
# 1.0 = 100% limit (effectively off while testing). Use e.g. 0.08 for production.
MAX_DRAWDOWN=1
LEVERAGE=10
RR=3.0
SL_ATR_MULT=1.0
TRAIL_ACTIVATE_ATR_MULT=1.5
TRAIL_DIST_ATR_MULT=0.5

ADX_PERIOD=14
ADX_THRESHOLD=25
TREND_MIN_ADX=34
TREND_MIN_MOVE_24H=0.08
MIN_BREADTH_COUNT=6
NEUTRAL_MIN_BREADTH_COUNT=3
BREADTH_PROBE_SYMBOLS=30
ATR_PERIOD=14
ATR_MIN_PCT=0.005
BOLL_PERIOD=20
BOLL_STD=2.0
STRATEGY_ENTRY_MODE=pump
STRATEGY_ENTRY_MODE_STRONG=pump
STRATEGY_ENTRY_MODE_NEUTRAL=hybrid
STRATEGY_ENTRY_MODE_WEAK=hybrid
WEAK_DISABLE_IMPULSE_ENTRIES=true
# Apply same entry tightenings as backtester --strict-filters in live/runtime.
STRICT_FILTERS_LIVE=true
PUMP_LOOKBACK=6
PUMP_MIN_RET_1H=0.02
PUMP_VOLUME_MULT=1.8
PUMP_CLOSE_POS_MIN=0.65
PUMP_MAX_OVEREXT_ATR=1.0
PUMP_MAX_OPP_WICK_RATIO=1.2
PUMP_SHORT_MIN_RET_1H=0.018
PUMP_SHORT_VOLUME_MULT=1.8
PUMP_SHORT_CLOSE_POS_MIN=0.65
PUMP_SHORT_MAX_OVEREXT_ATR=1.4
PUMP_SHORT_MAX_OPP_WICK_RATIO=1.0
PUMP_MIN_BODY_ATR_LONG=0.35
PUMP_MIN_BODY_ATR_SHORT=0.40
PUMP_MAX_RANGE_ATR=3.5
PUMP_BREAKOUT_BUFFER_ATR=0.10
PUMP_CONTINUATION_MIN_RATIO_LONG=0.985
PUMP_CONTINUATION_MAX_RATIO_SHORT=1.015

COOLDOWN_HOURS=48
LOSS_STREAK_BLOCK_THRESHOLD=2
LOSS_STREAK_BLOCK_HOURS=72
# Max position notional in USDT. 0 = no cap (size from RISK_PERCENT*equity and SL distance only).
LIVE_MAX_NOTIONAL_USDT=0
# Optional floor so the order passes MEXC min notional; 0 = do not bump size for min order.
LIVE_MIN_ORDER_NOTIONAL_USDT=0
# 0 = allow any number of open positions; N = at most N concurrent (live entries only).
LIVE_MAX_POSITIONS=0
# Realized PnL today (from state). Below -limit blocks new entries. 0 = disable this check.
LIVE_DAILY_LOSS_LIMIT_USDT=2.0
# Skip live entry if current mark deviates from signal entry by more than N ATR (0 = disable).
LIVE_ENTRY_MAX_DEVIATION_ATR=0.5
# Reject entries when executable risk (after contract rounding) differs from target by more than this fraction.
LIVE_RISK_MISMATCH_TOLERANCE=0.03
# stdout lines when signal exists but live open skipped (plan/qty/min notional).
ENTRY_BLOCK_LOG=true
PAPER_STAGED_EXITS=true
PAPER_STAGE2_R=3.0
PAPER_STAGE2_CLOSE_RATIO=0.50
PAPER_STAGED_FINAL_R=false
PAPER_STAGE3_R=5.0

FUTURES_TAKER_FEE_RATE=0.0004
SLIPPAGE_BPS=2.0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

API_HOST=0.0.0.0
API_PORT=8000
